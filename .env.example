# ============================================================
# ENVIRONMENT CONFIGURATION - Wealth Management App
# ============================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
# ============================================================

# ============================================================
# AI & Language Model Providers
# ============================================================

# OpenAI API Key - Used for GPT models
OPENAI_API_KEY=sk_test_...

# Anthropic API Key - Used for Claude models
ANTHROPIC_API_KEY=sk-ant-...

# Google Generative AI API Key - Used for Gemini models
GOOGLE_GENERATIVE_AI_API_KEY=...

# GitHub API Token - Used for Copilot models
GITHUB_TOKEN=ghp_...

# ============================================================
# Web Search Providers (Roundrobin: Tavily → Exa → DuckDuckGo)
# ============================================================

# Primary Web Search - Tavily API
# Benefits: Advanced search depth, high quality results, financial data optimized
# Get key at: https://tavily.com/api
TAVILY_API_KEY=tvly-...

# Fallback 1: Exa Web Search
# Benefits: Neural search, high precision, well-structured results
# Get key at: https://dashboard.exa.ai/api-keys
# Your API key: aee0b966-81df-4d4c-ab83-d8f7ced91f2f
EXA_API_KEY=aee0b966-81df-4d4c-ab83-d8f7ced91f2f

# Fallback 2: DuckDuckGo Search (via duck-duck-scrape)
# Benefits: No API key required, no rate limits, lightweight
# No configuration needed - automatically used as final fallback

# ============================================================
# Google Sheets Integration
# ============================================================

# Google Sheets API Key
GOOGLE_SHEETS_API_KEY=...

# Google Sheets Spreadsheet ID (contains account, transaction, budget data)
GOOGLE_SHEETS_ID=...

# ============================================================
# Data Sources & Market APIs
# ============================================================

# Yahoo Finance API (crypto, stocks)
# Note: Usually free, no API key required

# VNStock API (Vietnamese stocks)
# Endpoint: https://api.vnstock.info/

# CafeF API (Vietnamese market data)
# Endpoint: https://s.cafef.vn/

# CoinGecko API (cryptocurrency data)
# Note: Free tier available, no API key required for basic usage
# Premium: https://www.coingecko.com/en/api

# ============================================================
# Database & State Management
# ============================================================

# MongoDB Connection String (if using MongoDB backend)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/wealth-management

# Upstash Redis (for caching and session management)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# Application Settings
# ============================================================

# Next.js Environment
NODE_ENV=development
# Options: development, production, test

# API Base URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_ADVANCED_SEARCH=true
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true

# ============================================================
# Deployment & Infrastructure
# ============================================================

# Vercel Deployment Token (if using Vercel)
VERCEL_TOKEN=...

# ============================================================
# Development & Debugging
# ============================================================

# Enable verbose logging
DEBUG=wealth-management:*

# Enable request logging
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace

# ============================================================
# Notes & Best Practices
# ============================================================
#
# 1. SECURITY:
#    - Never commit .env.local to git
#    - Use .env.local for local development
#    - Use GitHub Secrets for CI/CD environments
#    - Rotate API keys regularly
#
# 2. SEARCH PROVIDER FALLBACK CHAIN:
#    The system automatically tries providers in order:
#    a) Tavily (if TAVILY_API_KEY is set) - Primary
#    b) Exa (if EXA_API_KEY is set) - Fallback 1
#    c) DuckDuckGo (always available) - Fallback 2
#    
#    If Tavily fails or returns no results, Exa is automatically tried.
#    If Exa fails, DuckDuckGo is used as the final fallback.
#    See: libs/wealth-management/src/services/services/search-service.ts
#
# 3. API KEY ACQUISITION:
#    - Tavily: https://tavily.com/api
#    - Exa: https://exa.ai
#    - OpenAI: https://platform.openai.com/api-keys
#    - Anthropic: https://console.anthropic.com
#    - Google: https://makersuite.google.com/app/apikey
#
# 4. TESTING WITHOUT API KEYS:
#    - DuckDuckGo fallback works without any API keys
#    - Useful for development and testing
#    - Results quality is good for most queries
#
# 5. MONITORING:
#    - Check logs for which provider is being used
#    - Search service logs: [SearchService] provider name
#    - Monitor API usage to avoid exceeding rate limits
