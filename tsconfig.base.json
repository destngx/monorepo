{
  "compileOnSave": false,
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cloudinary-photos-app/components/layout": ["libs/cloudinary-photos-app/components/layout/src/index.ts"],
      "@cloudinary-photos-app/components/layout/server": ["libs/cloudinary-photos-app/components/layout/src/server.ts"],
      "@cloudinary-photos-app/global-store": ["libs/cloudinary-photos-app/global-store/src/index.ts"],
      "@mono/cloudinary-photos-app/components/icons": ["libs/cloudinary-photos-app/components/icons/src/index.ts"],
      "@mono/cloudinary-photos-app/components/icons/server": [
        "libs/cloudinary-photos-app/components/icons/src/server.ts"
      ],
      "@mono/cloudinary-photos-app/components/ui": ["libs/cloudinary-photos-app/components/ui/src/index.ts"],
      "@mono/cloudinary-photos-app/components/ui/server": ["libs/cloudinary-photos-app/components/ui/src/server.ts"],
      "@mono/cloudinary-photos-app/types": ["libs/cloudinary-photos-app/types/src/index.ts"],
      "@mono/cloudinary-photos-app/utils": ["libs/cloudinary-photos-app/utils/src/index.ts"],
      "@task-management/config": ["libs/task-management/config/src/index.ts"],
      "@task-management/queue": ["libs/task-management/queue/src/index.ts"],
      "@wealth-management/types": ["libs/wealth-management-types/src/index.ts"],
      "@wealth-management/types/*": ["libs/wealth-management-types/src/*"],
      "@wealth-management/schemas": ["libs/wealth-management-schemas/src/index.ts"],
      "@wealth-management/schemas/*": ["libs/wealth-management-schemas/src/*"],
      "@wealth-management/ui": ["libs/wealth-management-ui/src/index.ts"],
      "@wealth-management/ui/*": ["libs/wealth-management-ui/src/*"],
      "@wealth-management/utils": ["libs/wealth-management-utils/src/index.ts"],
      "@wealth-management/utils/*": ["libs/wealth-management-utils/src/*"],
      "@wealth-management/services": ["libs/wealth-management-services/src/index.ts"],
      "@wealth-management/services/*": ["libs/wealth-management-services/src/*"],
      "@wealth-management/ai": ["libs/wealth-management-ai/src/index.ts"],
      "@wealth-management/ai/*": ["libs/wealth-management-ai/src/*"],
      "@task-management/queue": ["libs/task-management/queue/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", ".next", "dist", "out-tsc", "build", "coverage", "storybook-static"]
}
