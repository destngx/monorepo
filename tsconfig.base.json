{
  "compileOnSave": false,
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cloudinary-photos-app/components/layout": ["libs/cloudinary-photos-app/components/layout/src/index.ts"],
      "@cloudinary-photos-app/components/layout/server": ["libs/cloudinary-photos-app/components/layout/src/server.ts"],
      "@cloudinary-photos-app/global-store": ["libs/cloudinary-photos-app/global-store/src/index.ts"],
      "@mono/cloudinary-photos-app/components/icons": ["libs/cloudinary-photos-app/components/icons/src/index.ts"],
      "@mono/cloudinary-photos-app/components/icons/server": [
        "libs/cloudinary-photos-app/components/icons/src/server.ts"
      ],
      "@mono/cloudinary-photos-app/components/ui": ["libs/cloudinary-photos-app/components/ui/src/index.ts"],
      "@mono/cloudinary-photos-app/components/ui/server": ["libs/cloudinary-photos-app/components/ui/src/server.ts"],
      "@mono/cloudinary-photos-app/types": ["libs/cloudinary-photos-app/types/src/index.ts"],
      "@mono/cloudinary-photos-app/utils": ["libs/cloudinary-photos-app/utils/src/index.ts"],
      "@wealth-management/types": ["libs/wealth-management/src/types/index.ts"],
      "@wealth-management/types/*": ["libs/wealth-management/src/types/*"],
      "@wealth-management/schemas": ["libs/wealth-management/src/schemas/index.ts"],
      "@wealth-management/schemas/*": ["libs/wealth-management/src/schemas/*"],
      "@wealth-management/features": ["libs/wealth-management/src/features/index.ts"],
      "@wealth-management/features/*": ["libs/wealth-management/src/features/*"],
      "@wealth-management/config": ["libs/wealth-management/src/config/index.ts"],
      "@wealth-management/config/*": ["libs/wealth-management/src/config/*"],
      "@wealth-management/content": ["libs/wealth-management/src/content/index.ts"],
      "@wealth-management/content/*": ["libs/wealth-management/src/content/*"],
      "@wealth-management/ui": ["libs/wealth-management/src/ui/index.ts"],
      "@wealth-management/ui/*": ["libs/wealth-management/src/ui/*"],
      "@wealth-management/utils": ["libs/wealth-management/src/utils/index.ts"],
      "@wealth-management/utils/*": ["libs/wealth-management/src/utils/*"],
      "@wealth-management/ai": ["libs/wealth-management/src/ai/index.ts"],
      "@wealth-management/ai/*": ["libs/wealth-management/src/ai/*"],
      "@wealth-management/ai/server": ["libs/wealth-management/src/ai/server.ts"],
      "@wealth-management/services": ["libs/wealth-management/src/services/index.ts"],
      "@wealth-management/services/*": ["libs/wealth-management/src/services/*"],
      "@wealth-management/services/server": ["libs/wealth-management/src/services/server.ts"],
      "@wealth-management/hooks": ["libs/wealth-management/src/hooks/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", ".next", "dist", "out-tsc", "build", "coverage", "storybook-static"]
}
