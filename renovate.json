{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [],
  "enabledManagers": ["npm", "gomod", "pip_requirements"],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "commitMessagePrefix": "chore(deps): ",
  "commitBodyTable": true,
  "rebaseWhen": "behind-base-branch",
  "timezone": "Asia/Bangkok",
  "schedule": ["every weekend"],
  "major": {
    "dependencyDashboardApproval": true
  },
  "gomod": {
    "enabled": true
  },
  "pip_requirements": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchPaths": ["go.work", "apps/**/**"],
      "groupName": "go backend dependencies",
      "groupSlug": "go-backend",
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "matchManagers": ["pip_requirements"],
      "matchPaths": ["apps/**/**"],
      "groupName": "python backend dependencies",
      "groupSlug": "python-backend"
    },
    {
      "matchPackagePatterns": ["^eslint"],
      "groupName": "eslint and its plugins",
      "groupSlug": "eslint",
      "enabled": false
    },
    {
      "matchPackageNames": ["node", "bun", "@typescript-eslint/eslint-plugin", "@typescript-eslint/parser", "esbuild"],
      "enabled": false
    },
    {
      "matchDepTypes": ["peerDependencies"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "automergeType": "branch",
      "groupName": "all major dependencies",
      "groupSlug": "all-majors",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "minimumReleaseAge": "3 days"
    }
  ],
  "platformAutomerge": true
}
