{
  "name": "workflow-generator",
  "version": "1.0.1",
  "description": "Meta-workflow that converts a natural language query into a validated GraphWeave workflow DAG. Enforces deterministic transformation pipelines, structured outputs, and publishability recommendations.",
  "metadata": {
    "author": "platform-eng",
    "created_at": "2026-04-21T00:00:00Z",
    "tags": ["meta", "generator", "dag-builder", "structured-thinking"]
  },
  "limits": {
    "max_hops": 12,
    "max_tokens": 500000,
    "timeout_seconds": 120,
    "stagnation_window": 3,
    "stagnation_threshold": 2
  },
  "edges": [
    {
      "from": "entry",
      "to": "planner"
    },
    {
      "from": "planner",
      "to": "node_builder"
    },
    {
      "from": "node_builder",
      "to": "architecture_advisor"
    },
    {
      "from": "architecture_advisor",
      "to": "edge_router"
    },
    {
      "from": "edge_router",
      "to": "assembler"
    },
    {
      "from": "assembler",
      "to": "validation_gate"
    },
    {
      "from": "validation_gate",
      "to": "exit",
      "condition": "$.assembly_result.is_valid == true"
    },
    {
      "from": "validation_gate",
      "to": "exit",
      "condition": "$.assembly_result.is_valid == false"
    }
  ],
  "entry_point": "entry",
  "exit_point": "exit",
  "components": {
    "base_dir": "workflow-generator",
    "nodes": [
      "nodes/entry.json",
      "nodes/planner.json",
      "nodes/node_builder.json",
      "nodes/architecture_advisor.json",
      "nodes/edge_router.json",
      "nodes/assembler.json",
      "nodes/validation_gate.json",
      "nodes/exit.json"
    ]
  }
}
