# AI Gateway Configuration

# Provider Credentials
GITHUB_TOKEN=
OPENAI_API_KEY=
# Optional: enables refresh-token reuse for Codex/ChatGPT OAuth auth.json.
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_PATH=~/.codex/auth.json

ANTHROPIC_API_KEY=
# Anthropic /v1/messages route:
# default = github-copilot + gpt-5-mini + high reasoning effort
# openai-gpt-5.4-mini-low = openai + gpt-5.4-mini + low reasoning effort
ANTHROPIC_ROUTE=default

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Server Configuration
LISTEN_ADDR=:8080

# Logging Configuration
# VERBOSE=0 (default: standard logs)
# VERBOSE=1 (includes request/response details)
# VERBOSE=2 (includes internal application logic prints)
# VERBOSE=1

# Rate Limiting (Optional - 0 means unlimited)
# RPM: Requests Per Minute, Burst: Max spike size

GITHUB_RATE_RPM=0
GITHUB_RATE_BURST=0

OPENAI_RATE_RPM=0
OPENAI_RATE_BURST=0

ANTHROPIC_RATE_RPM=0
ANTHROPIC_RATE_BURST=0

OLLAMA_RATE_RPM=0
OLLAMA_RATE_BURST=0
