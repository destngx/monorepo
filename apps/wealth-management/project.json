{
  "name": "wealth-management",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/wealth-management/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "app:wealth-management",
    "scope:frontend"
  ],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "root": "apps/wealth-management",
        "outputPath": "dist/apps/wealth-management"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/wealth-management/.next"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "wealth-management:build",
        "dev": true
      },
      "configurations": {
        "development": {
          "buildTarget": "wealth-management:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "wealth-management:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/wealth-management/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{workspaceRoot}/coverage/apps/wealth-management"
      ],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/apps/wealth-management"
      }
    },
    "setup-ai": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun apps/wealth-management/scripts/setup-ai.ts"
      }
    },
    "setup-oauth": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun apps/wealth-management/scripts/setup-oauth.ts"
      }
    },
    "verify-auth": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun apps/wealth-management/scripts/verify-auth.ts"
      }
    }
  }
}
