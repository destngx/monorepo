UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# AI Gateway configuration (OpenAI-compatible proxy)
AI_GATEWAY_URL=http://localhost:8080/v1
AI_GATEWAY_TIMEOUT=60.0

# Bash Tool configuration
# Comma-separated list of extra absolute paths allowed for execution
BASH_TOOL_ALLOWED_PATHS=/usr/local/bin,/tmp/workspace

# E2E Test Configuration
# Set to the GraphWeave API endpoint. When not set, tests use TestClient (local)
# For live E2E testing: http://localhost:8001 or your deployed URL
GRAPH_WEAVE_API_URL=http://localhost:8001

# File System Tool configuration
# Comma-separated list of allowed absolute paths
FS_TOOL_ALLOWED_PATHS=/tmp/workspace,/app/data
# Path for soft-deleted files
FS_TOOL_TRASH_PATH=/tmp/workspace/.trash
