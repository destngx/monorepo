      { "name": "file_path", "type": "string" },
      { "name": "file_content", "type": "string" },
      { "name": "existing_tags", "type": "array" }
    ],
    "optional": []
  },
  "output_contract": {
    "produced": [
      { "name": "file_path", "type": "string", "state_path": "$.classify_metadata.file_path" },
      { "name": "file_content", "type": "string", "state_path": "$.classify_metadata.file_content" },
      { "name": "categories", "type": "array", "state_path": "$.classify_metadata.categories" },
      { "name": "tags", "type": "array", "state_path": "$.classify_metadata.tags" },
      { "name": "entities", "type": "array", "state_path": "$.classify_metadata.entities" }
    ]
  },
  "tags": ["classification", "metadata"],
  "owner": "system",
  "status": "active",
  "reuse_eligible": true,
