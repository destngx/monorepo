{
  "tenant_id": "system",
  "node_id": "classify_metadata:v1.0.0",
  "node_name": "classify_metadata",
  "version": "1.0.0",
  "name": "Classify Metadata",
  "type": "agent_node",
  "description": "Classify content and extract metadata",
  "config": {
    "system_prompt": "You are a metadata classifier. Analyze content and extract relevant metadata including categories, tags, and key entities.",
