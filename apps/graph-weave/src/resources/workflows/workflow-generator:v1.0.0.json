{
  "name": "workflow-generator",
  "version": "1.0.0",
  "description": "Meta-workflow that converts a natural language intent into a compositional workflow DAG. Searches registry for existing nodes and suggests missing ones.",
  "metadata": {
    "author": "platform-eng",
    "created_at": "2026-05-15T00:00:00Z",
    "tags": ["meta", "generator", "dag-builder", "compositional", "registry"]
  },
  "limits": {
    "max_hops": 15,
    "max_tokens": 500000,
    "timeout_seconds": 1800,
    "stagnation_window": 3,
    "stagnation_threshold": 2
  },
  "components": {
    "base_dir": "workflow-generator:v1.0.0",
    "nodes": [
      "nodes/entry.json",
      "nodes/planner.json",
      "nodes/node_builder.json",
      "nodes/architecture_advisor.json",
      "nodes/edge_router.json",
      "nodes/assembler.json",
      "nodes/validation_gate.json",
      "nodes/exit.json"
    ]
  },
  "edges": [
    {
      "from": "entry",
      "to": "planner"
    },
    {
      "from": "planner",
      "to": "node_builder"
    },
    {
      "from": "node_builder",
      "to": "architecture_advisor"
    },
    {
      "from": "architecture_advisor",
      "to": "edge_router"
    },
    {
      "from": "edge_router",
      "to": "assembler"
    },
    {
      "from": "assembler",
      "to": "validation_gate"
    },
    {
      "from": "validation_gate",
      "to": "exit",
      "condition": "$.nodes.assembler.result.is_valid == true"
    },
    {
      "from": "validation_gate",
      "to": "exit",
      "condition": "$.nodes.assembler.result.is_valid == false"
    }
  ],
  "entry_point": "entry",
  "exit_point": "exit"
}
