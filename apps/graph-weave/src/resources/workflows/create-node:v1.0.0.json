{
  "name": "create-node",
  "version": "1.0.0",
  "description": "System workflow that generates and registers a new node from description",
  "metadata": {
    "author": "platform-eng",
    "created_at": "2026-05-15T00:00:00Z",
    "tags": ["system", "node-creation", "registry"]
  },
  "limits": {
    "max_hops": 10,
    "max_tokens": 200000,
    "timeout_seconds": 300
  },
  "nodes": [
    {
      "id": "entry",
      "type": "entry",
      "display_name": "Entry"
    },
    {
      "alias": "config_generator",
      "node_id": "nodes:system:config_generator:v1.0.0"
    },
    {
      "alias": "node_assembler",
      "node_id": "nodes:system:node_assembler:v1.0.0"
    },
    {
      "id": "exit",
      "type": "exit",
      "display_name": "Exit"
    }
  ],
  "edges": [
    {
      "from": "entry",
      "to": "config_generator"
    },
    {
      "from": "config_generator",
      "to": "node_assembler"
    },
    {
      "from": "node_assembler",
      "to": "exit"
    }
  ],
  "entry_point": "entry",
  "exit_point": "exit"
}
