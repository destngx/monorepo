{
  "name": "create-node",
  "version": "1.0.0",
  "description": "System workflow that generates and registers a new node from description",
  "metadata": {
    "author": "platform-eng",
    "created_at": "2026-05-15T00:00:00Z",
    "tags": ["system", "node-creation", "registry"]
  },
  "limits": {
    "max_hops": 10,
    "max_tokens": 200000,
    "timeout_seconds": 300
  },
  "components": {
    "base_dir": "create-node:v1.0.0",
    "nodes": [
      "nodes/entry.json",
      "nodes/config_generator.json",
      "nodes/node_validator.json",
      "nodes/validation_gate.json",
      "nodes/node_assembler.json",
      "nodes/exit.json"
    ]
  },
  "edges": [
    {
      "from": "entry",
      "to": "config_generator"
    },
    {
      "from": "config_generator",
      "to": "node_validator"
    },
    {
      "from": "node_validator",
      "to": "validation_gate"
    },
    {
      "from": "validation_gate",
      "to": "node_assembler",
      "condition": "$.nodes.node_validator.result.is_valid == true"
    },
    {
      "from": "validation_gate",
      "to": "exit",
      "condition": "$.nodes.node_validator.result.is_valid == false"
    },
    {
      "from": "node_assembler",
      "to": "exit"
    }
  ],
  "entry_point": "entry",
  "exit_point": "exit"
}
