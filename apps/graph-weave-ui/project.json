{
  "name": "graph-weave-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/graph-weave-ui/src",
  "tags": ["type:app", "scope:gw"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpx vite build",
        "cwd": "apps/graph-weave-ui"
      },
      "configurations": {
        "production": {
          "command": "pnpx vite build --mode production",
          "cwd": "apps/graph-weave-ui"
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpx vite dev --host --port 8082",
        "cwd": "apps/graph-weave-ui"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpx svelte-check --tsconfig ./tsconfig.json",
        "cwd": "apps/graph-weave-ui"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpx eslint .",
        "cwd": "apps/graph-weave-ui"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpx vitest",
        "cwd": "apps/graph-weave-ui"
      }
    }
  }
}
