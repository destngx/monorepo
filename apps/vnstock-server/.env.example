# vnstock-server Environment Configuration

# VNSTOCK API Key - Required for authenticated access
# Get your API key from https://vnstocks.com/onboard-member/
# Community tier provides: higher rate limits, priority access, better reliability
VNSTOCK_API_KEY=your_api_key_here

# Server Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Data Source (VCI or KBS - VCI recommended for stability)
VNSTOCK_SOURCE=VCI

# Cache Configuration (Upstash Redis)
# Set to true to enable caching, false to disable
CACHE_ENABLED=true
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
