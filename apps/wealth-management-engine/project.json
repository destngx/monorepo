{
  "name": "wealth-management-engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/wealth-management-engine",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "main.go"
      },
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "executor": "@nx-go/nx-go:serve",
      "options": {
        "main": "main.go"
      },
      "cache": false
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p \"$PWD/../../tmp/go-build-cache\" \"$PWD/../../tmp/go-mod-cache\" && GOCACHE=\"$PWD/../../tmp/go-build-cache\" GOMODCACHE=\"$PWD/../../tmp/go-mod-cache\" go test ./...",
        "cwd": "apps/wealth-management-engine"
      }
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "find . -name '*.go' -not -path './tmp/*' -exec gofmt -w {} +",
        "cwd": "apps/wealth-management-engine"
      }
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    }
  }
}
